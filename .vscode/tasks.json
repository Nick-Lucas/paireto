{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": ["npm: watch:tsc", "npm: watch:esbuild"],
      "presentation": {
        "reveal": "never", // "silent" only opens the terminal if the command errors out
        "revealProblems": "never",
        "focus": false, // Keeps your cursor in the editor window
        "panel": "shared", // Reuses the same terminal instead of creating a new one each time
        "clear": true // Wipes old logs before running
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch:esbuild",
      "group": "build",
      "problemMatcher": "$esbuild-watch",
      "isBackground": true,
      "label": "npm: watch:esbuild",
      "presentation": {
        "group": "watch",
        "revealProblems": "never",
        "reveal": "never", // "silent" only opens the terminal if the command errors out
        "focus": false, // Keeps your cursor in the editor window
        "panel": "shared", // Reuses the same terminal instead of creating a new one each time
        "clear": true // Wipes old logs before running
      }
    },
    {
      "type": "npm",
      "script": "watch:tsc",
      "group": "build",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "label": "npm: watch:tsc",
