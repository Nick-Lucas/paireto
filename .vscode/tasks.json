    {
      "label": "tasks: watch-tests",
      "dependsOn": ["npm: watch", "npm: watch-tests"],
      "presentation": {
        "group": "watch",
        "revealProblems": "never",

        "reveal": "never", // "silent" only opens the terminal if the command errors out
