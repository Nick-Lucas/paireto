{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "SessionEnd": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "PostToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 },
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-review-gate.js\"", "timeout": 345600 }
        ]
      }
    ],
    "Notification": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "CwdChanged": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "FileChanged": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "WorktreeCreate": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "WorktreeRemove": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-event.js\"", "timeout": 5 }] }
    ],
    "PermissionRequest": [
      { "matcher": "ExitPlanMode", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/on-plan-gate.js\"", "timeout": 345600 }] }
    ]
  }
}
