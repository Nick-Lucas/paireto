{
  "name": "paireto",
  "displayName": "Paireto",
  "version": "0.8.0",
  "description": "Paireto — VS Code companion for terminal-first AI coding agents.",
  "categories": [
    "Other"
  ],
  "license": "ELv2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nick-Lucas/paireto"
  },
  "publisher": "Paireto",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run prepackage",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "prepackage": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "package": "vsce package --no-dependencies --out dist/paireto.vsix",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit && tsc -p scripts && tsc -p src/welcome/webview",
    "dogfood": "pnpm package && code --install-extension dist/paireto.vsix --force",
    "publish:minor": "vsce publish minor --no-dependencies",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "autofix": "oxlint --fix src && oxfmt src",
    "test": "vscode-test",
    "emulator": "node scripts/emulator.ts"
  },
  "dependencies": {
    "dedent": "^1.7.2",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "paireto.switcher.open",
        "title": "Paireto: Switch Repository / Worktree",
        "icon": "$(repo)"
      },
      {
        "command": "paireto.switcher.openInThisWindow",
        "title": "Paireto: Open Selected in This Window"
      },
      {
        "command": "paireto.openWelcome",
        "title": "Paireto: Open Welcome"
      },
      {
        "command": "paireto.gate.approve",
        "title": "Approve",
        "icon": "media/approve.svg"
      },
      {
        "command": "paireto.gate.sendFeedback",
        "title": "Send Feedback",
        "icon": "media/send-feedback.svg"
      },
      {
        "command": "paireto.submit",
        "title": "Paireto: Submit Feedback or Approve if no Feedback"
      },
      {
        "command": "paireto.comment.edit",
        "title": "Edit Comment",
        "icon": "$(edit)"
      },
      {
        "command": "paireto.comment.save",
        "title": "Save Comment",
        "icon": "$(check)"
      },
      {
        "command": "paireto.comment.delete",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "paireto.plan.addComment",
        "title": "Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "paireto.plan.addQuestion",
        "title": "Question",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "paireto.plan.addProblem",
        "title": "Problem",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "paireto.review.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "paireto.review.pickCompareTo",
        "title": "Compare To…",
        "icon": "$(git-compare)"
      },
      {
        "command": "paireto.review.toggleLayout",
        "title": "Toggle Flat / Tree View",
        "icon": "$(list-tree)"
      },
      {
        "command": "paireto.review.openDiff",
        "title": "Open Changes"
      },
      {
        "command": "paireto.review.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "paireto.review.stage",
        "title": "Stage Changes",
        "icon": "$(add)"
      },
      {
        "command": "paireto.review.unstage",
        "title": "Unstage Changes",
        "icon": "$(remove)"
      },
      {
        "command": "paireto.review.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "paireto.review.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      },
      {
        "command": "paireto.review.discard",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "paireto.review.discardAll",
        "title": "Discard All Changes",
        "icon": "$(discard)"
      },
      {
        "command": "paireto.review.addComment",
        "title": "Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "paireto.review.addQuestion",
        "title": "Question",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "paireto.review.addProblem",
        "title": "Problem",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "paireto.review.revealComment",
        "title": "Reveal Comment"
      },
      {
        "command": "paireto.review.deleteComment",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "paireto.focusAgent",
        "title": "Focus Agent",
        "icon": "$(terminal)"
      },
      {
        "command": "paireto.agent.switch",
        "title": "Switch to Agent"
      },
      {
        "command": "paireto.agent.hide",
        "title": "Hide Agent",
        "icon": "$(eye)"
      },
      {
        "command": "paireto.agent.show",
        "title": "Show Agent",
        "icon": "$(eye-closed)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "paireto",
          "title": "Paireto",
          "icon": "media/paireto.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "paireto.switcher.open",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k"
      },
      {
        "command": "paireto.switcher.openInThisWindow",
        "key": "shift+enter",
        "when": "paireto.switcherVisible"
      }
    ],
    "views": {
      "paireto": [
        {
          "id": "paireto.main",
          "name": "Paireto",
          "type": "tree",
          "icon": "media/paireto.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "paireto.switcher.openInThisWindow",
          "when": "false"
        },
        {
          "command": "paireto.submit",
          "when": "paireto.planPending || paireto.reviewSessionActive"
        },
        {
          "command": "paireto.plan.addQuestion",
          "when": "false"
        },
        {
          "command": "paireto.plan.addComment",
          "when": "false"
        },
        {
          "command": "paireto.plan.addProblem",
          "when": "false"
        },
        {
          "command": "paireto.review.addQuestion",
          "when": "false"
        },
        {
          "command": "paireto.review.addComment",
          "when": "false"
        },
        {
          "command": "paireto.review.addProblem",
          "when": "false"
        },
        {
          "command": "paireto.review.openDiff",
          "when": "false"
        },
        {
          "command": "paireto.review.openFile",
          "when": "false"
        },
        {
          "command": "paireto.review.stage",
          "when": "false"
        },
        {
          "command": "paireto.review.unstage",
          "when": "false"
        },
        {
          "command": "paireto.review.discard",
          "when": "false"
        },
        {
          "command": "paireto.review.revealComment",
          "when": "false"
        },
        {
          "command": "paireto.review.deleteComment",
          "when": "false"
        },
        {
          "command": "paireto.gate.approve",
          "when": "false"
        },
        {
          "command": "paireto.gate.sendFeedback",
          "when": "false"
        },
        {
          "command": "paireto.comment.edit",
          "when": "false"
        },
        {
          "command": "paireto.comment.save",
          "when": "false"
        },
        {
          "command": "paireto.comment.delete",
          "when": "false"
        },
        {
          "command": "paireto.agent.switch",
          "when": "false"
        },
        {
          "command": "paireto.agent.hide",
          "when": "false"
        },
        {
          "command": "paireto.agent.show",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "paireto.gate.approve",
          "when": "resourceScheme == paireto-plan && !paireto.gateHasFeedback",
          "group": "navigation@1"
        },
        {
          "command": "paireto.gate.sendFeedback",
          "when": "resourceScheme == paireto-plan && paireto.gateHasFeedback",
          "group": "navigation@2"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "paireto.plan.addComment",
          "when": "commentController == paireto.plan",
          "group": "inline@1"
        },
        {
          "command": "paireto.plan.addQuestion",
          "when": "commentController == paireto.plan",
          "group": "inline@2"
        },
        {
          "command": "paireto.plan.addProblem",
          "when": "commentController == paireto.plan",
          "group": "inline@3"
        },
        {
          "command": "paireto.review.addComment",
          "when": "commentController == paireto.review",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.addQuestion",
          "when": "commentController == paireto.review",
          "group": "inline@2"
        },
        {
          "command": "paireto.review.addProblem",
          "when": "commentController == paireto.review",
          "group": "inline@3"
        }
      ],
      "comments/comment/title": [
        {
          "command": "paireto.comment.edit",
          "when": "(commentController == paireto.plan || commentController == paireto.review) && comment == preview",
          "group": "group@1"
        },
        {
          "command": "paireto.comment.delete",
          "when": "(commentController == paireto.plan || commentController == paireto.review) && comment == preview",
          "group": "group@2"
        }
      ],
      "comments/comment/context": [
        {
          "command": "paireto.comment.save",
          "when": "(commentController == paireto.plan || commentController == paireto.review) && comment == editing",
          "group": "inline@1"
        }
      ],
      "view/item/context": [
        {
          "command": "paireto.review.pickCompareTo",
          "when": "view == paireto.main && viewItem == section:files",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.toggleLayout",
          "when": "view == paireto.main && viewItem == section:files",
          "group": "inline@2"
        },
        {
          "command": "paireto.focusAgent",
          "when": "view == paireto.main && viewItem =~ /^agentSession/",
          "group": "inline@1"
        },
        {
          "command": "paireto.agent.hide",
          "when": "view == paireto.main && viewItem == agentSession",
          "group": "inline@2"
        },
        {
          "command": "paireto.agent.show",
          "when": "view == paireto.main && viewItem == agentSession:muted",
          "group": "inline@2"
        },
        {
          "command": "paireto.review.deleteComment",
          "when": "view == paireto.main && viewItem == reviewComment",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.discardAll",
          "when": "view == paireto.main && viewItem == group:unstaged",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.stageAll",
          "when": "view == paireto.main && viewItem == group:unstaged",
          "group": "inline@2"
        },
        {
          "command": "paireto.review.unstageAll",
          "when": "view == paireto.main && viewItem == group:staged",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.openFile",
          "when": "view == paireto.main && viewItem =~ /^changedFile:/",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.discard",
          "when": "view == paireto.main && viewItem == changedFile:unstaged",
          "group": "inline@2"
        },
        {
          "command": "paireto.review.stage",
          "when": "view == paireto.main && viewItem == changedFile:unstaged",
          "group": "inline@3"
        },
        {
          "command": "paireto.review.unstage",
          "when": "view == paireto.main && viewItem == changedFile:staged",
          "group": "inline@2"
        },
        {
          "command": "paireto.review.openFile",
          "when": "view == paireto.main && viewItem =~ /^changedFile:/",
          "group": "1_open@1"
        },
        {
          "command": "paireto.review.openDiff",
          "when": "view == paireto.main && viewItem =~ /^changedFile:/",
          "group": "1_open@2"
        },
        {
          "command": "paireto.review.stage",
          "when": "view == paireto.main && viewItem == changedFile:unstaged",
          "group": "2_git@1"
        },
        {
          "command": "paireto.review.discard",
          "when": "view == paireto.main && viewItem == changedFile:unstaged",
          "group": "2_git@2"
        },
        {
          "command": "paireto.review.unstage",
          "when": "view == paireto.main && viewItem == changedFile:staged",
          "group": "2_git@1"
        },
        {
          "command": "paireto.review.stage",
          "when": "view == paireto.main && viewItem == folder:unstaged",
          "group": "inline@2"
        },
        {
          "command": "paireto.review.discard",
          "when": "view == paireto.main && viewItem == folder:unstaged",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.unstage",
          "when": "view == paireto.main && viewItem == folder:staged",
          "group": "inline@1"
        },
        {
          "command": "paireto.review.stage",
          "when": "view == paireto.main && viewItem == folder:unstaged",
          "group": "2_git@1"
        },
        {
          "command": "paireto.review.discard",
          "when": "view == paireto.main && viewItem == folder:unstaged",
          "group": "2_git@2"
        },
        {
          "command": "paireto.review.unstage",
          "when": "view == paireto.main && viewItem == folder:staged",
          "group": "2_git@1"
        }
      ],
      "view/title": [
        {
          "command": "paireto.review.refresh",
          "when": "view == paireto.main",
          "group": "navigation@3"
        },
        {
          "command": "paireto.gate.approve",
          "when": "view == paireto.main && (paireto.planPending || paireto.reviewSessionActive) && !paireto.gateHasFeedback",
          "group": "navigation@4"
        },
        {
          "command": "paireto.gate.sendFeedback",
          "when": "view == paireto.main && (paireto.planPending || paireto.reviewSessionActive) && paireto.gateHasFeedback",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Paireto",
      "properties": {
        "paireto.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Paireto's log level."
        },
        "paireto.notify.type": {
          "type": "string",
          "enum": [
            "sound",
            "disabled"
          ],
          "enumDescriptions": [
            "Play the selected sound when an agent needs you.",
            "No sound (the sidebar, status bar, and switcher indicators still update)."
          ],
          "default": "sound",
          "description": "How to alert you when one of this window's agents finishes a turn or needs input (stopped / awaiting plan / awaiting permission)."
        },
        "paireto.notify.sound": {
          "type": "string",
          "default": "Ping",
          "description": "Sound played when 'paireto.notify.type' is 'sound': a system-sound name (e.g. macOS 'Glass', 'Ping', 'Hero') or an absolute path to a sound file."
        },
        "paireto.review.mode": {
          "type": "string",
          "enum": [
            "automatic",
            "manual"
          ],
          "enumDescriptions": [
            "Open a Review automatically when the agent finishes a turn that edited files.",
            "Only start a review if you have queued comments when the agent finishes, or when running /paireto-review from your agent."
          ],
          "default": "automatic",
          "description": "When Paireto opens a code Review at the end of an agent's turn."
        },
        "paireto.planApprove.mode": {
          "type": "object",
          "default": {
            "claudecode": "auto"
          },
          "additionalProperties": {
            "type": "string",
            "enum": [
              "auto",
              "acceptEdits",
              "default",
              "plan",
              "off"
            ]
          },
          "description": "Per-harness permission mode the agent enters when you approve its plan, keyed by harness id (e.g. \"claudecode\"). Values: auto (auto-approve with background safety checks), acceptEdits (auto-approve file edits), default (ask for permission), plan (stay in plan mode), off (leave the mode unchanged)."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "media/PairetoAppIcon@2x.png",
  "engines": {
    "vscode": "^1.120.0"
  }
}
