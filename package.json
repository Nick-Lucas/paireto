{
  "name": "tui-companion",
  "displayName": "tui-companion",
  "description": "Companion for TUI AI Harnesses",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tui-companion.openSwitcher",
        "title": "TUI Companion: Switch Repository / Worktree",
        "icon": "$(repo)"
      },
      {
        "command": "tui-companion.switcher.acceptThisWindow",
        "title": "TUI Companion: Open Selected in This Window"
      },
      {
        "command": "tui-companion.plan.approve",
        "title": "Approve Plan",
        "icon": "$(check)"
      },
      {
        "command": "tui-companion.plan.sendFeedback",
        "title": "Send Plan Feedback to Claude",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "tui-companion.plan.addComment",
        "title": "Add Comment"
      },
      {
        "command": "tui-companion.plan.setSeverity.blocking",
        "title": "Mark Blocking"
      },
      {
        "command": "tui-companion.plan.setSeverity.suggestion",
        "title": "Mark Suggestion"
      },
      {
        "command": "tui-companion.plan.setSeverity.note",
        "title": "Mark Note"
      },
      {
        "command": "tui-companion.review.refresh",
        "title": "Refresh Review",
        "icon": "$(refresh)"
      },
      {
        "command": "tui-companion.review.pickMode",
        "title": "Change Review Mode",
        "icon": "$(list-selection)"
      },
      {
        "command": "tui-companion.review.pickBase",
        "title": "Change Base Ref",
        "icon": "$(git-branch)"
      },
      {
        "command": "tui-companion.review.toggleUntracked",
        "title": "Toggle Untracked Files"
      },
      {
        "command": "tui-companion.review.openDiff",
        "title": "Open Diff"
      },
      {
        "command": "tui-companion.review.sendFeedback",
        "title": "Send Review Feedback to Claude",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "tui-companion.review.export",
        "title": "Export Review",
        "icon": "$(save)"
      },
      {
        "command": "tui-companion.review.addComment",
        "title": "Add Comment"
      },
      {
        "command": "tui-companion.review.setSeverity.blocking",
        "title": "Mark Blocking"
      },
      {
        "command": "tui-companion.review.setSeverity.suggestion",
        "title": "Mark Suggestion"
      },
      {
        "command": "tui-companion.review.setSeverity.note",
        "title": "Mark Note"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tui-companion",
          "title": "TUI Companion",
          "icon": "media/tui-companion.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tui-companion.openSwitcher",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k"
      },
      {
        "command": "tui-companion.switcher.acceptThisWindow",
        "key": "shift+enter",
        "when": "tui.switcherVisible"
      }
    ],
    "views": {
      "tui-companion": [
        {
          "id": "tui.reviewTree",
          "name": "Code Review",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "tui-companion.switcher.acceptThisWindow",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "tui-companion.plan.approve",
          "when": "resourceScheme == tui-plan",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.plan.sendFeedback",
          "when": "resourceScheme == tui-plan",
          "group": "navigation@2"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "tui-companion.plan.addComment",
          "when": "commentController == tui.plan",
          "group": "inline"
        },
        {
          "command": "tui-companion.review.addComment",
          "when": "commentController == tui.review",
          "group": "inline"
        }
      ],
      "comments/comment/title": [
        {
          "command": "tui-companion.plan.setSeverity.blocking",
          "when": "commentController == tui.plan",
          "group": "1_severity@1"
        },
        {
          "command": "tui-companion.plan.setSeverity.suggestion",
          "when": "commentController == tui.plan",
          "group": "1_severity@2"
        },
        {
          "command": "tui-companion.plan.setSeverity.note",
          "when": "commentController == tui.plan",
          "group": "1_severity@3"
        },
        {
          "command": "tui-companion.review.setSeverity.blocking",
          "when": "commentController == tui.review",
          "group": "1_severity@1"
        },
        {
          "command": "tui-companion.review.setSeverity.suggestion",
          "when": "commentController == tui.review",
          "group": "1_severity@2"
        },
        {
          "command": "tui-companion.review.setSeverity.note",
          "when": "commentController == tui.review",
          "group": "1_severity@3"
        }
      ],
      "view/title": [
        {
          "command": "tui-companion.review.pickMode",
          "when": "view == tui.reviewTree",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.review.pickBase",
          "when": "view == tui.reviewTree",
          "group": "navigation@2"
        },
        {
          "command": "tui-companion.review.refresh",
          "when": "view == tui.reviewTree",
          "group": "navigation@3"
        },
        {
          "command": "tui-companion.review.sendFeedback",
          "when": "view == tui.reviewTree",
          "group": "1_actions@1"
        },
        {
          "command": "tui-companion.review.export",
          "when": "view == tui.reviewTree",
          "group": "1_actions@2"
        }
      ]
    },
    "configuration": {
      "title": "TUI Companion",
      "properties": {
        "tui-companion.plugin.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically register the bundled Claude Code plugin on activation."
        },
        "tui-companion.planGate.onUnavailable": {
          "type": "string",
          "enum": ["fail-open", "fail-visible", "deny"],
          "default": "fail-open",
          "description": "Plan-gate behavior when no VS Code window is listening for this repo."
        },
        "tui-companion.planGate.onTimeout": {
          "type": "string",
          "enum": ["fail-open", "fail-visible", "deny"],
          "default": "fail-visible",
          "description": "Plan-gate behavior when the review times out."
        },
        "tui-companion.planGate.onMalformed": {
          "type": "string",
          "enum": ["fail-open", "fail-visible", "deny"],
          "default": "fail-visible",
          "description": "Plan-gate behavior on a malformed response."
        },
        "tui-companion.planGate.timeoutSeconds": {
          "type": "number",
          "default": 345600,
          "description": "Maximum seconds the plan gate blocks waiting for a review decision."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "autofix": "oxlint --fix src && oxfmt src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.9.3"
  }
}
