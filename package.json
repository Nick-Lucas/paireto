{
  "name": "tui-companion",
  "displayName": "tui-companion",
  "description": "Companion for TUI AI Harnesses",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tui-companion.openSwitcher",
        "title": "TUI Companion: Switch Repository / Worktree",
        "icon": "$(repo)"
      },
      {
        "command": "tui-companion.switcher.acceptThisWindow",
        "title": "TUI Companion: Open Selected in This Window"
      },
      {
        "command": "tui-companion.plan.approve",
        "title": "Approve Plan",
        "icon": "$(check)"
      },
      {
        "command": "tui-companion.plan.sendFeedback",
        "title": "Send Plan Feedback to Claude",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "tui-companion.plan.addComment",
        "title": "Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.plan.addQuestion",
        "title": "Question",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.plan.addProblem",
        "title": "Problem",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.refresh",
        "title": "Refresh Review",
        "icon": "$(refresh)"
      },
      {
        "command": "tui-companion.review.pickMode",
        "title": "Change Review Mode",
        "icon": "$(git-compare)"
      },
      {
        "command": "tui-companion.review.pickBase",
        "title": "Change Base Ref",
        "icon": "$(git-branch)"
      },
      {
        "command": "tui-companion.review.openDiff",
        "title": "Open Diff"
      },
      {
        "command": "tui-companion.review.sendFeedback",
        "title": "Send Feedback",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "tui-companion.review.clearFeedback",
        "title": "Clear Feedback",
        "icon": "$(clear-all)"
      },
      {
        "command": "tui-companion.review.export",
        "title": "Export Review",
        "icon": "$(save)"
      },
      {
        "command": "tui-companion.review.addComment",
        "title": "Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.addQuestion",
        "title": "Question",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.addProblem",
        "title": "Problem",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.revealComment",
        "title": "Reveal Comment"
      },
      {
        "command": "tui-companion.review.deleteComment",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "tui-companion.review.cancel",
        "title": "Cancel Review",
        "icon": "$(close)"
      },
      {
        "command": "tui-companion.focusAgent",
        "title": "Focus Agent",
        "icon": "$(terminal)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tui-companion",
          "title": "TUI Companion",
          "icon": "media/tui-companion.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tui-companion.openSwitcher",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k"
      },
      {
        "command": "tui-companion.switcher.acceptThisWindow",
        "key": "shift+enter",
        "when": "tui.switcherVisible"
      },
      {
        "command": "editor.action.submitComment",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "win": "ctrl+enter",
        "linux": "ctrl+enter",
        "when": "commentEditorFocused && (commentController == tui.plan || commentController == tui.review)"
      }
    ],
    "views": {
      "tui-companion": [
        {
          "id": "tui.agents",
          "name": "Agents",
          "type": "tree"
        },
        {
          "id": "tui.planReview",
          "name": "Plan Review",
          "type": "tree",
          "when": "tui.planPending"
        },
        {
          "id": "tui.review",
          "name": "Review",
          "type": "tree",
          "when": "tui.reviewSessionActive"
        },
        {
          "id": "tui.reviewFeedback",
          "name": "Feedback",
          "type": "tree",
          "when": "tui.reviewSessionActive"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tui.agents",
        "contents": "No Claude Code agents connected yet.\n\nStart `claude` in a terminal inside this repository — sessions appear here once the plugin's hooks fire.\n\nRun `/tui-review` in an agent to open a code review."
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tui-companion.switcher.acceptThisWindow",
          "when": "false"
        },
        { "command": "tui-companion.plan.addQuestion", "when": "false" },
        { "command": "tui-companion.plan.addComment", "when": "false" },
        { "command": "tui-companion.plan.addProblem", "when": "false" },
        { "command": "tui-companion.review.addQuestion", "when": "false" },
        { "command": "tui-companion.review.addComment", "when": "false" },
        { "command": "tui-companion.review.addProblem", "when": "false" },
        { "command": "tui-companion.review.openDiff", "when": "false" },
        { "command": "tui-companion.review.revealComment", "when": "false" },
        { "command": "tui-companion.review.deleteComment", "when": "false" }
      ],
      "editor/title": [
        {
          "command": "tui-companion.plan.approve",
          "when": "resourceScheme == tui-plan",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.plan.sendFeedback",
          "when": "resourceScheme == tui-plan",
          "group": "navigation@2"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "tui-companion.plan.addComment",
          "when": "commentController == tui.plan",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.plan.addQuestion",
          "when": "commentController == tui.plan",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.plan.addProblem",
          "when": "commentController == tui.plan",
          "group": "inline@3"
        },
        {
          "command": "tui-companion.review.addComment",
          "when": "commentController == tui.review",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.addQuestion",
          "when": "commentController == tui.review",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.review.addProblem",
          "when": "commentController == tui.review",
          "group": "inline@3"
        }
      ],
      "view/item/context": [
        {
          "command": "tui-companion.review.deleteComment",
          "when": "view == tui.reviewFeedback && viewItem == reviewComment",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "tui-companion.focusAgent",
          "when": "view == tui.agents",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.plan.approve",
          "when": "view == tui.planReview",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.plan.sendFeedback",
          "when": "view == tui.planReview",
          "group": "navigation@2"
        },
        {
          "command": "tui-companion.review.pickMode",
          "when": "view == tui.review",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.review.pickBase",
          "when": "view == tui.review",
          "group": "navigation@2"
        },
        {
          "command": "tui-companion.review.refresh",
          "when": "view == tui.review",
          "group": "navigation@3"
        },
        {
          "command": "tui-companion.review.cancel",
          "when": "view == tui.review",
          "group": "navigation@4"
        },
        {
          "command": "tui-companion.review.sendFeedback",
          "when": "view == tui.reviewFeedback",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.review.clearFeedback",
          "when": "view == tui.reviewFeedback",
          "group": "navigation@2"
        },
        {
          "command": "tui-companion.review.export",
          "when": "view == tui.reviewFeedback",
          "group": "navigation@3"
        },
        {
          "command": "tui-companion.review.cancel",
          "when": "view == tui.reviewFeedback",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "TUI Companion",
      "properties": {
        "tui-companion.plugin.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically register the bundled Claude Code plugin on activation."
        },
        "tui-companion.planGate.onUnavailable": {
          "type": "string",
          "enum": ["fail-open", "fail-visible", "deny"],
          "default": "fail-open",
          "description": "Plan-gate behavior when no VS Code window is listening for this repo."
        },
        "tui-companion.planGate.onTimeout": {
          "type": "string",
          "enum": ["fail-open", "fail-visible", "deny"],
          "default": "fail-visible",
          "description": "Plan-gate behavior when the review times out."
        },
        "tui-companion.planGate.onMalformed": {
          "type": "string",
          "enum": ["fail-open", "fail-visible", "deny"],
          "default": "fail-visible",
          "description": "Plan-gate behavior on a malformed response."
        },
        "tui-companion.planGate.timeoutSeconds": {
          "type": "number",
          "default": 345600,
          "description": "Maximum seconds the plan gate blocks waiting for a review decision."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "autofix": "oxlint --fix src && oxfmt src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.9.3"
  }
}
