{
  "name": "tui-companion",
  "displayName": "tui-companion",
  "version": "0.0.1",
  "description": "Companion for TUI AI Harnesses",
  "categories": [
    "Other"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nick-Lucas/vscode-tui-companion"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run prepackage",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "prepackage": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "package": "vsce package --out dist/tui-companion.vsix",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit && tsc -p plugins/claude-code",
    "dogfood": "pnpm package && code --install-extension dist/tui-companion.vsix --force",
    "lint": "oxlint src",
    "format": "oxfmt --check src",
    "autofix": "oxlint --fix src && oxfmt src",
    "test": "vscode-test",
    "emulator": "node plugins/claude-code/scripts/emulator.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "tui-companion.openSwitcher",
        "title": "TUI Companion: Switch Repository / Worktree",
        "icon": "$(repo)"
      },
      {
        "command": "tui-companion.switcher.acceptThisWindow",
        "title": "TUI Companion: Open Selected in This Window"
      },
      {
        "command": "tui-companion.gate.approve",
        "title": "Approve",
        "icon": "media/approve.svg"
      },
      {
        "command": "tui-companion.gate.sendFeedback",
        "title": "Send Feedback",
        "icon": "media/send-feedback.svg"
      },
      {
        "command": "tui-companion.comment.edit",
        "title": "Edit Comment",
        "icon": "$(edit)"
      },
      {
        "command": "tui-companion.comment.save",
        "title": "Save Comment",
        "icon": "$(check)"
      },
      {
        "command": "tui-companion.comment.delete",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "tui-companion.plan.addComment",
        "title": "Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.plan.addQuestion",
        "title": "Question",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.plan.addProblem",
        "title": "Problem",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "tui-companion.review.pickCompareTo",
        "title": "Compare To…",
        "icon": "$(git-compare)"
      },
      {
        "command": "tui-companion.review.toggleLayout",
        "title": "Toggle Flat / Tree View",
        "icon": "$(list-tree)"
      },
      {
        "command": "tui-companion.review.openDiff",
        "title": "Open Changes"
      },
      {
        "command": "tui-companion.review.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "tui-companion.review.stage",
        "title": "Stage Changes",
        "icon": "$(add)"
      },
      {
        "command": "tui-companion.review.unstage",
        "title": "Unstage Changes",
        "icon": "$(remove)"
      },
      {
        "command": "tui-companion.review.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)"
      },
      {
        "command": "tui-companion.review.unstageAll",
        "title": "Unstage All Changes",
        "icon": "$(remove)"
      },
      {
        "command": "tui-companion.review.discard",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "tui-companion.review.discardAll",
        "title": "Discard All Changes",
        "icon": "$(discard)"
      },
      {
        "command": "tui-companion.review.addComment",
        "title": "Comment",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.addQuestion",
        "title": "Question",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.addProblem",
        "title": "Problem",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "tui-companion.review.revealComment",
        "title": "Reveal Comment"
      },
      {
        "command": "tui-companion.review.deleteComment",
        "title": "Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "tui-companion.focusAgent",
        "title": "Focus Agent",
        "icon": "$(terminal)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tui-companion",
          "title": "TUI Companion",
          "icon": "media/tui-companion.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tui-companion.openSwitcher",
        "key": "cmd+shift+k",
        "mac": "cmd+shift+k",
        "win": "ctrl+shift+k",
        "linux": "ctrl+shift+k"
      },
      {
        "command": "tui-companion.switcher.acceptThisWindow",
        "key": "shift+enter",
        "when": "tui.switcherVisible"
      },
      {
        "command": "editor.action.submitComment",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "win": "ctrl+enter",
        "linux": "ctrl+enter",
        "when": "commentEditorFocused && (commentController == tui.plan || commentController == tui.review)"
      }
    ],
    "views": {
      "tui-companion": [
        {
          "id": "tui.main",
          "name": "TUI Companion",
          "type": "tree",
          "icon": "media/tui-companion.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "tui-companion.switcher.acceptThisWindow",
          "when": "false"
        },
        {
          "command": "tui-companion.plan.addQuestion",
          "when": "false"
        },
        {
          "command": "tui-companion.plan.addComment",
          "when": "false"
        },
        {
          "command": "tui-companion.plan.addProblem",
          "when": "false"
        },
        {
          "command": "tui-companion.review.addQuestion",
          "when": "false"
        },
        {
          "command": "tui-companion.review.addComment",
          "when": "false"
        },
        {
          "command": "tui-companion.review.addProblem",
          "when": "false"
        },
        {
          "command": "tui-companion.review.openDiff",
          "when": "false"
        },
        {
          "command": "tui-companion.review.openFile",
          "when": "false"
        },
        {
          "command": "tui-companion.review.stage",
          "when": "false"
        },
        {
          "command": "tui-companion.review.unstage",
          "when": "false"
        },
        {
          "command": "tui-companion.review.discard",
          "when": "false"
        },
        {
          "command": "tui-companion.review.revealComment",
          "when": "false"
        },
        {
          "command": "tui-companion.review.deleteComment",
          "when": "false"
        },
        {
          "command": "tui-companion.gate.approve",
          "when": "false"
        },
        {
          "command": "tui-companion.gate.sendFeedback",
          "when": "false"
        },
        {
          "command": "tui-companion.comment.edit",
          "when": "false"
        },
        {
          "command": "tui-companion.comment.save",
          "when": "false"
        },
        {
          "command": "tui-companion.comment.delete",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "tui-companion.gate.approve",
          "when": "resourceScheme == tui-plan",
          "group": "navigation@1"
        },
        {
          "command": "tui-companion.gate.sendFeedback",
          "when": "resourceScheme == tui-plan",
          "group": "navigation@2"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "tui-companion.plan.addComment",
          "when": "commentController == tui.plan",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.plan.addQuestion",
          "when": "commentController == tui.plan",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.plan.addProblem",
          "when": "commentController == tui.plan",
          "group": "inline@3"
        },
        {
          "command": "tui-companion.review.addComment",
          "when": "commentController == tui.review",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.addQuestion",
          "when": "commentController == tui.review",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.review.addProblem",
          "when": "commentController == tui.review",
          "group": "inline@3"
        }
      ],
      "comments/comment/title": [
        {
          "command": "tui-companion.comment.edit",
          "when": "(commentController == tui.plan || commentController == tui.review) && comment == preview",
          "group": "group@1"
        },
        {
          "command": "tui-companion.comment.delete",
          "when": "(commentController == tui.plan || commentController == tui.review) && comment == preview",
          "group": "group@2"
        }
      ],
      "comments/comment/context": [
        {
          "command": "tui-companion.comment.save",
          "when": "(commentController == tui.plan || commentController == tui.review) && comment == editing",
          "group": "inline@1"
        }
      ],
      "view/item/context": [
        {
          "command": "tui-companion.review.pickCompareTo",
          "when": "view == tui.main && viewItem == section:files",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.toggleLayout",
          "when": "view == tui.main && viewItem == section:files",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.focusAgent",
          "when": "view == tui.main && viewItem == agentSession",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.deleteComment",
          "when": "view == tui.main && viewItem == reviewComment",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.discardAll",
          "when": "view == tui.main && viewItem == group:unstaged",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.stageAll",
          "when": "view == tui.main && viewItem == group:unstaged",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.review.unstageAll",
          "when": "view == tui.main && viewItem == group:staged",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.openFile",
          "when": "view == tui.main && viewItem =~ /^changedFile:/",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.discard",
          "when": "view == tui.main && viewItem == changedFile:unstaged",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.review.stage",
          "when": "view == tui.main && viewItem == changedFile:unstaged",
          "group": "inline@3"
        },
        {
          "command": "tui-companion.review.unstage",
          "when": "view == tui.main && viewItem == changedFile:staged",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.review.openFile",
          "when": "view == tui.main && viewItem =~ /^changedFile:/",
          "group": "1_open@1"
        },
        {
          "command": "tui-companion.review.openDiff",
          "when": "view == tui.main && viewItem =~ /^changedFile:/",
          "group": "1_open@2"
        },
        {
          "command": "tui-companion.review.stage",
          "when": "view == tui.main && viewItem == changedFile:unstaged",
          "group": "2_git@1"
        },
        {
          "command": "tui-companion.review.discard",
          "when": "view == tui.main && viewItem == changedFile:unstaged",
          "group": "2_git@2"
        },
        {
          "command": "tui-companion.review.unstage",
          "when": "view == tui.main && viewItem == changedFile:staged",
          "group": "2_git@1"
        },
        {
          "command": "tui-companion.review.stage",
          "when": "view == tui.main && viewItem == folder:unstaged",
          "group": "inline@2"
        },
        {
          "command": "tui-companion.review.discard",
          "when": "view == tui.main && viewItem == folder:unstaged",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.unstage",
          "when": "view == tui.main && viewItem == folder:staged",
          "group": "inline@1"
        },
        {
          "command": "tui-companion.review.stage",
          "when": "view == tui.main && viewItem == folder:unstaged",
          "group": "2_git@1"
        },
        {
          "command": "tui-companion.review.discard",
          "when": "view == tui.main && viewItem == folder:unstaged",
          "group": "2_git@2"
        },
        {
          "command": "tui-companion.review.unstage",
          "when": "view == tui.main && viewItem == folder:staged",
          "group": "2_git@1"
        }
      ],
      "view/title": [
        {
          "command": "tui-companion.review.refresh",
          "when": "view == tui.main",
          "group": "navigation@3"
        },
        {
          "command": "tui-companion.gate.approve",
          "when": "view == tui.main && (tui.planPending || tui.reviewSessionActive)",
          "group": "navigation@4"
        },
        {
          "command": "tui-companion.gate.sendFeedback",
          "when": "view == tui.main && (tui.planPending || tui.reviewSessionActive)",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "TUI Companion",
      "properties": {
        "tui-companion.plugin.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically register the bundled Claude Code plugin on activation."
        },
        "tui-companion.debug": {
          "type": "boolean",
          "default": false,
          "description": "Log TUI Companion diagnostics (refreshes, diff open decisions) to the 'TUI Companion' output channel."
        },
        "tui-companion.planGate.onUnavailable": {
          "type": "string",
          "enum": [
            "fail-open",
            "fail-visible",
            "deny"
          ],
          "default": "fail-open",
          "description": "Plan-gate behavior when no VS Code window is listening for this repo."
        },
        "tui-companion.planGate.onTimeout": {
          "type": "string",
          "enum": [
            "fail-open",
            "fail-visible",
            "deny"
          ],
          "default": "fail-visible",
          "description": "Plan-gate behavior when the review times out."
        },
        "tui-companion.planGate.onMalformed": {
          "type": "string",
          "enum": [
            "fail-open",
            "fail-visible",
            "deny"
          ],
          "default": "fail-visible",
          "description": "Plan-gate behavior on a malformed response."
        },
        "tui-companion.planGate.timeoutSeconds": {
          "type": "number",
          "default": 345600,
          "description": "Maximum seconds the plan gate blocks waiting for a review decision."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.120.0"
  }
}
