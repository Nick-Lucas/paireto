{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "curly": "warn",
    "eqeqeq": "warn",
    "no-throw-literal": "warn"
  },
  "env": {
    "builtin": true,
    "node": true,
    "browser": true
  }
}
